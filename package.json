{
  "name": "homework",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:emulator": "node scripts/seed-admin.mjs && npm run dev",
    "dev:all": "node scripts/free-emulator-ports.mjs && firebase emulators:exec --only auth,firestore \"npm run dev:emulator\"",
    "free-ports": "node scripts/free-emulator-ports.mjs",
    "seed-admin": "node scripts/seed-admin.mjs",
    "seed-developer": "node scripts/seed-developer.mjs",
    "clear-data": "node scripts/clear-emulator-data.mjs",
    "reset-emulator": "node scripts/reset-emulator.mjs",
    "emulators": "firebase emulators:start --only auth,firestore",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "firebase-deploy-rules": "firebase deploy --only firestore:rules",
    "firebase-deploy-indexes": "firebase deploy --only firestore:indexes",
    "firebase-deploy-firestore": "firebase deploy --only firestore"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-tools": "^14.9.0",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}

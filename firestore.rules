rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserProfile() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return hasUserProfile()
        && userDoc().data.role == 'admin';
    }

    function isStaff() {
      return hasUserProfile()
        && userDoc().data.role in ['manager', 'developer', 'admin'];
    }

    function isManager() {
      return hasUserProfile()
        && userDoc().data.role in ['manager', 'admin'];
    }

    function isCustomer() {
      return hasUserProfile()
        && userDoc().data.role == 'customer';
    }

    function isAssignedDeveloper(orderData) {
      return hasUserProfile()
        && userDoc().data.role == 'developer'
        && orderData.assignedDeveloperId == request.auth.uid;
    }

    function validUserCreate() {
      return request.resource.data.role == 'customer'
        && request.resource.data.developerRequestStatus in ['none', 'pending'];
    }

    function isBootstrapAdminCreate(userId) {
      return request.auth != null
        && request.auth.uid == userId
        && request.resource.data.role == 'admin'
        && request.resource.data.email == 'admin@gmail.com'
        && request.resource.data.developerRequestStatus == 'none';
    }

    function isBootstrapManagerCreate(userId) {
      return request.auth != null
        && request.auth.uid == userId
        && request.resource.data.role == 'manager'
        && request.resource.data.developerRequestStatus == 'none';
    }

    function validUserSelfUpdate() {
      return request.resource.data.role == resource.data.role
        && (
          request.resource.data.developerRequestStatus == resource.data.developerRequestStatus
          || (
            resource.data.developerRequestStatus in ['none', 'rejected']
            && request.resource.data.developerRequestStatus == 'pending'
          )
        );
    }

    function validUserProfileSelfUpdate(targetUserId) {
      return request.auth.uid == targetUserId
        && request.resource.data.role == resource.data.role
        && request.resource.data.email == resource.data.email
        && request.resource.data.developerRequestStatus == resource.data.developerRequestStatus
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 100
        && request.resource.data.companyName is string
        && request.resource.data.companyName.size() <= 120
        && request.resource.data.phone is string
        && request.resource.data.phone.size() <= 30
        && (
          resource.data.role != 'developer'
          || (
            request.resource.data.bio is string
            && request.resource.data.experienceCategories is list
            && request.resource.data.experienceYears is string
          )
        );
    }

    function validBootstrapAdminSelfUpgrade(userId) {
      return request.auth.uid == userId
        && resource.data.email == 'admin@gmail.com'
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == 'admin'
        && request.resource.data.developerRequestStatus == 'none';
    }

    function validAdminUserRoleUpdate(targetUserId) {
      return isAdmin()
        && request.auth.uid != targetUserId
        && request.resource.data.email == resource.data.email
        && request.resource.data.role in ['customer', 'manager', 'developer', 'admin']
        && request.resource.data.developerRequestStatus in ['none', 'pending', 'approved', 'rejected'];
    }

    function validTicketCreate() {
      return isCustomer()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.status == 'new'
        && request.resource.data.priority in ['urgent', 'tomorrow', 'flexible']
        && request.resource.data.serviceType is string
        && request.resource.data.description is string
        && request.resource.data.customerName is string
        && request.resource.data.assignedDeveloperId == null
        && (!('attachments' in request.resource.data) || request.resource.data.attachments == []);
    }

    function customerAttachmentFinalize() {
      return isCustomer()
        && resource.data.customerId == request.auth.uid
        && resource.data.status == 'new'
        && request.resource.data.status == 'new'
        && request.resource.data.customerId == resource.data.customerId
        && request.resource.data.customerName == resource.data.customerName
        && request.resource.data.serviceType == resource.data.serviceType
        && request.resource.data.description == resource.data.description
        && request.resource.data.priority == resource.data.priority
        && request.resource.data.assignedDeveloperId == null
        && request.resource.data.attachments is list
        && request.resource.data.attachments.size() <= 5;
    }

    function customerPriceDecision() {
      return isCustomer()
        && resource.data.customerId == request.auth.uid
        && resource.data.status == 'quote_offered'
        && request.resource.data.status in ['quote_confirmed', 'quote_rejected']
        && request.resource.data.price == resource.data.price
        && request.resource.data.customerId == resource.data.customerId
        && request.resource.data.serviceType == resource.data.serviceType
        && request.resource.data.description == resource.data.description
        && request.resource.data.priority == resource.data.priority
        && request.resource.data.attachments == resource.data.attachments;
    }

    function customerRatingUpdate() {
      return isCustomer()
        && resource.data.customerId == request.auth.uid
        && resource.data.status == 'completed'
        && resource.data.customerRating == null
        && request.resource.data.customerRating is number
        && request.resource.data.customerRating >= 1
        && request.resource.data.customerRating <= 5
        && request.resource.data.status == 'completed'
        && request.resource.data.attachments == resource.data.attachments;
    }

    match /users/{userId} {
      allow get: if request.auth != null && (
        request.auth.uid == userId
        || isManager()
        || (isStaff()
          && resource.data.keys().hasAll(['role'])
          && resource.data.role in ['manager', 'developer', 'admin'])
        || (resource.data.role == 'developer'
          && hasUserProfile()
          && userDoc().data.role in ['customer', 'manager', 'admin'])
      );

      allow list: if isAdmin();

      allow list: if isManager()
        && resource.data.keys().hasAll(['developerRequestStatus'])
        && resource.data.developerRequestStatus == 'pending';

      allow list: if isStaff()
        && resource.data.keys().hasAll(['role'])
        && (resource.data.role == 'developer' || resource.data.role == 'manager');

      allow list: if hasUserProfile()
        && userDoc().data.role in ['customer', 'manager', 'admin']
        && resource.data.keys().hasAll(['role'])
        && resource.data.role == 'developer';

      allow create: if request.auth != null
        && request.auth.uid == userId
        && (validUserCreate() || isBootstrapAdminCreate(userId) || isBootstrapManagerCreate(userId));

      allow update: if request.auth != null && (
        (request.auth.uid == userId && validUserSelfUpdate())
        || (request.auth.uid == userId && validUserProfileSelfUpdate(userId))
        || validBootstrapAdminSelfUpgrade(userId)
        || validAdminUserRoleUpdate(userId)
      );

      match /reviews/{reviewId} {
        allow read: if request.auth != null
          && hasUserProfile()
          && userDoc().data.role in ['customer', 'manager', 'admin'];

        allow create: if isCustomer()
          && exists(/databases/$(database)/documents/orders/$(reviewId))
          && get(/databases/$(database)/documents/orders/$(reviewId)).data.customerId == request.auth.uid
          && get(/databases/$(database)/documents/orders/$(reviewId)).data.assignedDeveloperId == userId
          && get(/databases/$(database)/documents/orders/$(reviewId)).data.status == 'completed'
          && request.resource.data.rating is number
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5;
      }
    }

    match /siteContent/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if request.auth != null && (
        isManager()
        || isAssignedDeveloper(resource.data)
        || resource.data.customerId == request.auth.uid
      );

      allow create: if validTicketCreate() || (
        isManager()
        && request.resource.data.status == 'new'
        && request.resource.data.customerId is string
      );

      allow update: if isManager()
        || customerPriceDecision()
        || customerAttachmentFinalize()
        || customerRatingUpdate()
        || (
          isAssignedDeveloper(resource.data)
          && request.resource.data.status in ['in_progress', 'completed']
          && request.resource.data.assignedDeveloperId == resource.data.assignedDeveloperId
          && request.resource.data.assignedDeveloperName == resource.data.assignedDeveloperName
          && request.resource.data.customerId == resource.data.customerId
          && request.resource.data.customerName == resource.data.customerName
          && request.resource.data.serviceType == resource.data.serviceType
          && request.resource.data.description == resource.data.description
          && request.resource.data.managerNotes == resource.data.managerNotes
          && request.resource.data.attachments == resource.data.attachments
          && request.resource.data.price == resource.data.price
          && request.resource.data.paymentStatus == resource.data.paymentStatus
          && request.resource.data.developerPayout == resource.data.developerPayout
          && request.resource.data.payoutStatus == resource.data.payoutStatus
          && request.resource.data.priority == resource.data.priority
        );
    }
  }
}

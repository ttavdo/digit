rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserProfile() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isStaff() {
      return hasUserProfile()
        && userDoc().data.role in ['manager', 'developer'];
    }

    function isManager() {
      return hasUserProfile()
        && userDoc().data.role == 'manager';
    }

    function isCustomer() {
      return hasUserProfile()
        && userDoc().data.role == 'customer';
    }

    function isAssignedDeveloper(orderData) {
      return hasUserProfile()
        && userDoc().data.role == 'developer'
        && orderData.assignedDeveloperId == request.auth.uid;
    }

    function validUserCreate() {
      return request.resource.data.role == 'customer'
        && request.resource.data.developerRequestStatus in ['none', 'pending'];
    }

    function isBootstrapManagerCreate(userId) {
      return request.auth != null
        && request.auth.uid == userId
        && request.resource.data.role == 'manager'
        && request.resource.data.email == 'admin@gmail.com'
        && request.resource.data.developerRequestStatus == 'none';
    }

    function validUserSelfUpdate() {
      return request.resource.data.role == resource.data.role
        && (
          request.resource.data.developerRequestStatus == resource.data.developerRequestStatus
          || (
            resource.data.developerRequestStatus in ['none', 'rejected']
            && request.resource.data.developerRequestStatus == 'pending'
          )
        );
    }

    function validDeveloperProfileUpdate() {
      return request.auth.uid == userId
        && userDoc().data.role == 'developer'
        && request.resource.data.role == 'developer'
        && request.resource.data.developerRequestStatus == resource.data.developerRequestStatus
        && request.resource.data.email == resource.data.email;
    }

    function validTicketCreate() {
      return isCustomer()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.status == 'new'
        && request.resource.data.priority in ['urgent', 'tomorrow', 'flexible']
        && request.resource.data.serviceType is string
        && request.resource.data.description is string
        && request.resource.data.customerName is string
        && request.resource.data.assignedDeveloperId == null;
    }

    function customerPriceDecision() {
      return isCustomer()
        && resource.data.customerId == request.auth.uid
        && resource.data.status == 'quote_offered'
        && request.resource.data.status in ['quote_confirmed', 'quote_rejected']
        && request.resource.data.price == resource.data.price
        && request.resource.data.customerId == resource.data.customerId
        && request.resource.data.serviceType == resource.data.serviceType
        && request.resource.data.description == resource.data.description
        && request.resource.data.priority == resource.data.priority;
    }

    function customerRatingUpdate() {
      return isCustomer()
        && resource.data.customerId == request.auth.uid
        && resource.data.status == 'completed'
        && resource.data.customerRating == null
        && request.resource.data.customerRating is number
        && request.resource.data.customerRating >= 1
        && request.resource.data.customerRating <= 5
        && request.resource.data.status == 'completed';
    }

    match /users/{userId} {
      allow get: if request.auth != null && (
        request.auth.uid == userId
        || isManager()
        || (isStaff()
          && resource.data.keys().hasAll(['role'])
          && resource.data.role in ['manager', 'developer'])
      );

      allow list: if isManager()
        && resource.data.keys().hasAll(['developerRequestStatus'])
        && resource.data.developerRequestStatus == 'pending';

      allow list: if isStaff()
        && resource.data.keys().hasAll(['role'])
        && (resource.data.role == 'developer' || resource.data.role == 'manager');

      allow create: if request.auth != null
        && request.auth.uid == userId
        && (validUserCreate() || isBootstrapManagerCreate(userId));

      allow update: if request.auth != null && (
        (request.auth.uid == userId && validUserSelfUpdate())
        || (request.auth.uid == userId && validDeveloperProfileUpdate())
        || isManager()
      );
    }

    match /orders/{orderId} {
      allow read: if request.auth != null && (
        isManager()
        || isAssignedDeveloper(resource.data)
        || resource.data.customerId == request.auth.uid
      );

      allow create: if validTicketCreate() || (
        isManager()
        && request.resource.data.status == 'new'
        && request.resource.data.customerId is string
      );

      allow update: if isManager()
        || customerPriceDecision()
        || customerRatingUpdate()
        || (
          isAssignedDeveloper(resource.data)
          && request.resource.data.status in ['in_progress', 'completed']
          && request.resource.data.assignedDeveloperId == resource.data.assignedDeveloperId
          && request.resource.data.assignedDeveloperName == resource.data.assignedDeveloperName
          && request.resource.data.customerId == resource.data.customerId
          && request.resource.data.customerName == resource.data.customerName
          && request.resource.data.serviceType == resource.data.serviceType
          && request.resource.data.description == resource.data.description
          && request.resource.data.managerNotes == resource.data.managerNotes
          && request.resource.data.price == resource.data.price
          && request.resource.data.paymentStatus == resource.data.paymentStatus
          && request.resource.data.developerPayout == resource.data.developerPayout
          && request.resource.data.payoutStatus == resource.data.payoutStatus
          && request.resource.data.priority == resource.data.priority
        );
    }
  }
}

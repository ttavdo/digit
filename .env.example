# ── ვარიანტი A: რეალური Firebase (digit-3147a) ──
VITE_USE_FIREBASE_EMULATOR=false

VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=digit-3147a.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=digit-3147a
VITE_FIREBASE_STORAGE_BUCKET=digit-3147a.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

VITE_BOOTSTRAP_ADMIN_EMAILS=admin@gmail.com
VITE_BOOTSTRAP_MANAGER_EMAILS=

# ── Vercel / Netlify ──
# Set the same VITE_* vars in your host dashboard (Vercel: Project → Settings → Environment Variables).

